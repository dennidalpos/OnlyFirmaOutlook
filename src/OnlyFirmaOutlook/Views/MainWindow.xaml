<Window x:Class="OnlyFirmaOutlook.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OnlyFirmaOutlook - Generatore Firme"
        Height="850" Width="750"
        MinHeight="750" MinWidth="650"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3">

    <Window.Resources>
        <!-- Stile base per GroupBox -->
        <Style x:Key="StepGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <!-- Stile per step completato -->
        <Style x:Key="CompletedStepStyle" TargetType="GroupBox" BasedOn="{StaticResource StepGroupBoxStyle}">
            <Setter Property="BorderBrush" Value="#4CAF50"/>
        </Style>

        <!-- Stile per step corrente (next action) -->
        <Style x:Key="CurrentStepStyle" TargetType="GroupBox" BasedOn="{StaticResource StepGroupBoxStyle}">
            <Setter Property="BorderBrush" Value="#1976D2"/>
            <Setter Property="BorderThickness" Value="3"/>
        </Style>

        <!-- Stile per step non ancora raggiunto -->
        <Style x:Key="PendingStepStyle" TargetType="GroupBox" BasedOn="{StaticResource StepGroupBoxStyle}">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Overlay per stato busy -->
        <Grid x:Name="BusyOverlay" Visibility="Collapsed" Panel.ZIndex="100">
            <Rectangle Fill="#80000000"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                <TextBlock x:Name="BusyMessage" Text="Elaborazione in corso..."
                           Foreground="White" FontSize="14" Margin="0,10,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Contenuto principale -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <!-- Titolo -->
                <TextBlock Text="OnlyFirmaOutlook" FontSize="24" FontWeight="Bold"
                           Foreground="#0078D4" Margin="0,0,0,4"/>
                <TextBlock Text="Converti documenti Word in firme per Outlook"
                           FontSize="12" Foreground="#605E5C" Margin="0,0,0,16"/>

                <!-- Warning Outlook -->
                <Border x:Name="OutlookWarningBorder" Visibility="Collapsed"
                        Background="#FFF4CE" BorderBrush="#C19600" BorderThickness="1"
                        CornerRadius="2" Padding="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock x:Name="OutlookWarningText" TextWrapping="Wrap"
                                   Foreground="#6B5B00" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- STEP 1: Selezione documento sorgente -->
                <GroupBox x:Name="Step1Group" Header="1. Seleziona firma da modificare *" Style="{StaticResource CurrentStepStyle}">
                    <StackPanel>
                        <TextBlock Text="Preset disponibili:" Margin="0,0,0,4"/>
                        <ListBox x:Name="PresetListBox" Height="100"/>
                        <TextBlock x:Name="NoPresetsText" Text="Nessun preset disponibile nella cartella media"
                                   Visibility="Collapsed" Foreground="#A19F9D"
                                   FontStyle="Italic" Margin="8"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="LoadCustomButton" Content="📁 Carica file Word..."
                                    Click="LoadCustomButton_Click"/>
                            <TextBlock x:Name="SelectedFileText" Text="Nessun file selezionato"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       Foreground="#605E5C"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- STEP 2: Configurazione firma -->
                <GroupBox x:Name="Step2Group" Header="2. Configura nome e account" Style="{StaticResource PendingStepStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Nome firma -->
                        <Label Content="Nome firma *:" Grid.Row="0" Grid.Column="0"
                               VerticalAlignment="Center"/>
                        <TextBox x:Name="SignatureNameTextBox" Grid.Row="0" Grid.Column="1"
                                 TextChanged="SignatureNameTextBox_TextChanged"/>

                        <!-- Account Outlook (visibile solo se Outlook disponibile) -->
                        <Label x:Name="AccountLabel" Content="Account Outlook:"
                               Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                               Margin="0,8,0,0"/>
                        <ComboBox x:Name="AccountComboBox" Grid.Row="1" Grid.Column="1"
                                  Margin="0,8,0,0"
                                  SelectionChanged="AccountComboBox_SelectionChanged"/>

                        <!-- Identificativo (visibile solo se Outlook NON disponibile) -->
                        <Label x:Name="IdentifierLabel" Content="Identificativo:"
                               Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                               Margin="0,8,0,0" Visibility="Collapsed"/>
                        <TextBox x:Name="IdentifierTextBox" Grid.Row="2" Grid.Column="1"
                                 Margin="0,8,0,0" Visibility="Collapsed"/>
                        <TextBlock x:Name="IdentifierHint" Grid.Row="3" Grid.Column="1"
                                   Text="(Opzionale, es. email o nome utente)"
                                   Foreground="#A19F9D" FontSize="11" Visibility="Collapsed"/>

                        <!-- Nome firma finale -->
                        <Border Grid.Row="4" Grid.ColumnSpan="2" Background="#E8F5E9"
                                CornerRadius="4" Padding="10" Margin="0,12,0,0"
                                x:Name="FinalNameBorder" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Nome finale:" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <TextBlock x:Name="FinalSignatureNameText" FontWeight="Bold" Foreground="#2E7D32"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </GroupBox>

                <!-- STEP 3: Cartella destinazione -->
                <GroupBox x:Name="Step3Group" Header="3. Cartella destinazione" Style="{StaticResource PendingStepStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="DestinationFolderTextBox" Grid.Column="0"
                                     IsReadOnly="True"/>
                            <Button x:Name="BrowseFolderButton" Content="Sfoglia..."
                                    Grid.Column="1" Click="BrowseFolderButton_Click"/>
                        </Grid>

                        <TextBlock x:Name="FolderWritableText" Margin="0,4,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- STEP 4: Modifica firma (obbligatorio) -->
                <GroupBox x:Name="Step4Group" Header="4. Modifica firma in Word *" Style="{StaticResource PendingStepStyle}">
                    <StackPanel>
                        <Border Background="#FFF4CE" BorderBrush="#C19600" BorderThickness="1"
                                CornerRadius="2" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#6B5B00">
                                    <Run Text="⚠ " FontWeight="Bold"/>
                                    <Run Text="Tutte le firme devono essere modificate in Word prima della conversione."/>
                                </TextBlock>
                                <TextBlock Text="Modifica il documento in Word, salvalo (Ctrl+S) e chiudilo. Lo stato si aggiornerà automaticamente."
                                           Foreground="#6B5B00" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Stato:" FontWeight="SemiBold" VerticalAlignment="Center"
                                       Grid.Column="0" Margin="0,0,8,0"/>
                            <TextBlock x:Name="EditStatusText" Text="Seleziona prima una firma"
                                       VerticalAlignment="Center" Grid.Column="1"
                                       Foreground="Gray"/>
                            <Button x:Name="EditSignatureButton" Content="📝 Apri in Word"
                                    Grid.Column="2" Click="EditSignatureButton_Click"
                                    IsEnabled="False" MinWidth="130"/>
                        </Grid>

                        <!-- Indicatore Word aperto -->
                        <Border x:Name="WordOpenIndicator" Visibility="Collapsed"
                                Background="#E3F2FD" BorderBrush="#1976D2" BorderThickness="1"
                                CornerRadius="2" Padding="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📖 " FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Word è aperto - modifica e salva il documento, poi chiudi Word"
                                           Foreground="#1565C0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <!-- STEP 5: Opzioni HTML -->
                <GroupBox x:Name="Step5Group" Header="5. Formato HTML" Style="{StaticResource PendingStepStyle}">
                    <StackPanel>
                        <RadioButton x:Name="FilteredHtmlRadio" Content="HTML Filtrato (consigliato)"
                                     IsChecked="True" GroupName="HtmlType"/>
                        <TextBlock Text="Rimuove stili e formattazioni non necessarie. Più leggero e compatibile."
                                   Foreground="#605E5C" FontSize="11" Margin="20,0,0,8"/>

                        <RadioButton x:Name="CompleteHtmlRadio" Content="HTML Completo"
                                     GroupName="HtmlType"/>
                        <TextBlock Text="Mantiene tutti gli stili Word. File più grande, possibili problemi di visualizzazione."
                                   Foreground="#605E5C" FontSize="11" Margin="20,0,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- STEP 6: Firme esistenti -->
                <GroupBox x:Name="Step6Group" Header="6. Firme esistenti (verifica sovrascrittura)" Style="{StaticResource PendingStepStyle}">
                    <StackPanel>
                        <!-- Warning sovrascrittura -->
                        <Border x:Name="OverwriteWarningBorder" Visibility="Collapsed"
                                Background="#FFEBEE" BorderBrush="#C62828" BorderThickness="1"
                                CornerRadius="2" Padding="10" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠ " FontSize="14" Foreground="#C62828" VerticalAlignment="Center"/>
                                <TextBlock x:Name="OverwriteWarningText" Foreground="#C62828"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <ListBox x:Name="ExistingSignaturesListBox" Height="80"
                                 SelectionChanged="ExistingSignaturesListBox_SelectionChanged"/>
                        <TextBlock x:Name="NoSignaturesText" Text="Nessuna firma esistente"
                                   Visibility="Collapsed" Foreground="#A19F9D"
                                   FontStyle="Italic" Margin="8"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="DeleteSignatureButton" Content="Elimina firma"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Click="DeleteSignatureButton_Click" IsEnabled="False"/>
                            <Button x:Name="RefreshSignaturesButton" Content="Aggiorna lista"
                                    Click="RefreshSignaturesButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Pulsante conversione -->
                <Button x:Name="ConvertButton" Content="✓ Converti e salva firma"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalAlignment="Stretch" Height="48"
                        Click="ConvertButton_Click" IsEnabled="False"
                        FontSize="15" FontWeight="Bold"
                        Margin="0,4,0,16"/>

                <!-- Log -->
                <GroupBox Header="Log">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="120"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox x:Name="LogTextBox" Grid.Row="0"
                                 Style="{StaticResource LogTextBoxStyle}"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"/>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="CopyLogButton" Content="Copia log"
                                    Click="CopyLogButton_Click"/>
                            <Button x:Name="ClearLogButton" Content="Pulisci log"
                                    Click="ClearLogButton_Click"/>
                            <Button x:Name="OpenLogFileButton" Content="Apri file log"
                                    Click="OpenLogFileButton_Click"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
