<Window x:Class="OnlyFirmaOutlook.Windows.WordEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Editor Firma"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="#FFFFFF"
        Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Status Bar -->
            <RowDefinition Height="*"/>
            <!-- Word Editor Info -->
            <RowDefinition Height="Auto"/>
            <!-- Bottom Buttons -->
        </Grid.RowDefinitions>

        <!-- Status Bar -->
        <Border Grid.Row="0" Background="#E8E8E8" BorderBrush="#CCCCCC" BorderThickness="0,1" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="Stato:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusTextBlock" Text="Caricamento in corso..." VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="UnsavedChangesTextBlock"
                           Grid.Column="2"
                           Text="Modifiche non salvate"
                           Foreground="OrangeRed"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Word Editor Info -->
        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Margin="10" Background="#F8F8F8" CornerRadius="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="📝" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Microsoft Word è aperto in una finestra separata"
                           FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Modifica il documento nella finestra di Word, poi torna qui per salvare."
                           FontSize="14" Foreground="#666666" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <Button x:Name="BringWordToFrontButton" Content="🔍 Porta Word in primo piano"
                        Click="BringWordToFrontButton_Click"
                        Padding="20,10" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Bottom Buttons -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Side Info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚠" FontSize="16" Foreground="DarkOrange" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="#666666">
                        <Run Text="Il documento deve essere salvato almeno una volta prima di poter procedere con la conversione."/>
                    </TextBlock>
                </StackPanel>

                <!-- Right Side Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="SaveButton"
                            Content="💾 Salva"
                            Click="SaveButton_Click"
                            ToolTip="Salva le modifiche al documento"/>

                    <Button x:Name="SaveAndCloseButton"
                            Content="✓ Salva e chiudi"
                            Click="SaveAndCloseButton_Click"
                            Background="#4CAF50"
                            Foreground="White"
                            FontWeight="SemiBold"
                            ToolTip="Salva e chiudi l'editor per procedere con la conversione"/>

                    <Button x:Name="CancelButton"
                            Content="✕ Annulla"
                            Click="CancelButton_Click"
                            ToolTip="Chiudi senza salvare le modifiche recenti"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Busy Overlay -->
        <Grid x:Name="BusyOverlay" Grid.RowSpan="3" Background="#AA000000" Visibility="Collapsed">
            <Border Background="White"
                    CornerRadius="8"
                    Padding="30,20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="250">
                <StackPanel>
                    <TextBlock x:Name="BusyMessage"
                               Text="Caricamento documento..."
                               FontSize="14"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>
                    <ProgressBar IsIndeterminate="True" Height="6" Width="200"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
