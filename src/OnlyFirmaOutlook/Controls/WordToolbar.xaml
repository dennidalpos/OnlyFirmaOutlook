<UserControl x:Class="OnlyFirmaOutlook.Controls.WordToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="60" d:DesignWidth="800">
    <Border Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="8,6">
        <WrapPanel Orientation="Horizontal">

            
            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                <Label Content="Font:" VerticalAlignment="Center" Padding="0,0,4,0"/>
                <ComboBox x:Name="FontComboBox" Width="140" Height="28" VerticalContentAlignment="Center"
                          SelectionChanged="FontComboBox_SelectionChanged"/>
            </StackPanel>

            
            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                <Label Content="Dimensione:" VerticalAlignment="Center" Padding="0,0,4,0"/>
                <ComboBox x:Name="FontSizeComboBox" Width="60" Height="28" VerticalContentAlignment="Center"
                          IsEditable="True" SelectionChanged="FontSizeComboBox_SelectionChanged">
                    <ComboBoxItem Content="8"/>
                    <ComboBoxItem Content="9"/>
                    <ComboBoxItem Content="10"/>
                    <ComboBoxItem Content="11"/>
                    <ComboBoxItem Content="12" IsSelected="True"/>
                    <ComboBoxItem Content="14"/>
                    <ComboBoxItem Content="16"/>
                    <ComboBoxItem Content="18"/>
                    <ComboBoxItem Content="20"/>
                    <ComboBoxItem Content="22"/>
                    <ComboBoxItem Content="24"/>
                    <ComboBoxItem Content="28"/>
                    <ComboBoxItem Content="36"/>
                    <ComboBoxItem Content="48"/>
                    <ComboBoxItem Content="72"/>
                </ComboBox>
            </StackPanel>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>

            
            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                <ToggleButton x:Name="BoldButton" Width="32" Height="28" FontWeight="Bold" Content="G"
                              ToolTip="Grassetto" Click="BoldButton_Click" Margin="2,0"/>
                <ToggleButton x:Name="ItalicButton" Width="32" Height="28" FontStyle="Italic" Content="C"
                              ToolTip="Corsivo" Click="ItalicButton_Click" Margin="2,0"/>
                <ToggleButton x:Name="UnderlineButton" Width="32" Height="28" Content="S"
                              ToolTip="Sottolineato" Click="UnderlineButton_Click" Margin="2,0">
                    <ToggleButton.ContentTemplate>
                        <DataTemplate>
                            <TextBlock Text="S" TextDecorations="Underline"/>
                        </DataTemplate>
                    </ToggleButton.ContentTemplate>
                </ToggleButton>
                <Button x:Name="FontColorButton" Width="32" Height="28" Content="A"
                        ToolTip="Colore testo" Click="FontColorButton_Click" Margin="2,0">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="A" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Border Height="3" Background="Red" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                            </Grid>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>

            
            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                <ToggleButton x:Name="AlignLeftButton" Width="32" Height="28" Content="≡"
                              ToolTip="Allinea a sinistra" Click="AlignLeftButton_Click" Margin="2,0"/>
                <ToggleButton x:Name="AlignCenterButton" Width="32" Height="28" Content="≡"
                              ToolTip="Centra" Click="AlignCenterButton_Click" Margin="2,0">
                    <ToggleButton.LayoutTransform>
                        <ScaleTransform ScaleX="0.8"/>
                    </ToggleButton.LayoutTransform>
                </ToggleButton>
                <ToggleButton x:Name="AlignRightButton" Width="32" Height="28" Content="≡"
                              ToolTip="Allinea a destra" Click="AlignRightButton_Click" Margin="2,0">
                    <ToggleButton.LayoutTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </ToggleButton.LayoutTransform>
                </ToggleButton>
            </StackPanel>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>

            
            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                <Button x:Name="InsertLinkButton" Width="60" Height="28" Content="Link"
                        ToolTip="Inserisci collegamento" Click="InsertLinkButton_Click" Margin="2,0"/>
                <Button x:Name="InsertImageButton" Width="70" Height="28" Content="Immagine"
                        ToolTip="Inserisci immagine" Click="InsertImageButton_Click" Margin="2,0"/>
            </StackPanel>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>

            
            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                <Button x:Name="UndoButton" Width="60" Height="28" Content="↶ Annulla"
                        ToolTip="Annulla" Click="UndoButton_Click" Margin="2,0"/>
                <Button x:Name="RedoButton" Width="60" Height="28" Content="Ripeti ↷"
                        ToolTip="Ripeti" Click="RedoButton_Click" Margin="2,0"/>
            </StackPanel>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>

            
            <StackPanel Orientation="Horizontal" Margin="0,0,4,0" VerticalAlignment="Center">
                <Button x:Name="ZoomOutButton" Width="32" Height="28" Content="-"
                        ToolTip="Riduci zoom" Click="ZoomOutButton_Click" Margin="2,0"/>
                <TextBlock x:Name="ZoomTextBlock" Text="100%" VerticalAlignment="Center"
                           MinWidth="40" TextAlignment="Center" Margin="4,0"/>
                <Button x:Name="ZoomInButton" Width="32" Height="28" Content="+"
                        ToolTip="Aumenta zoom" Click="ZoomInButton_Click" Margin="2,0"/>
            </StackPanel>

        </WrapPanel>
    </Border>
</UserControl>
